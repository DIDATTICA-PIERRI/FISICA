*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Source Sans 3',sans-serif;background:#faf9f6;color:#1a1a1e;min-height:100vh}
.topbar{background:#1a1a1e;padding:14px 32px;display:flex;align-items:center;gap:10px}
