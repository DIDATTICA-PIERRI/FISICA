.tags{display:flex;gap:5px;flex-wrap:wrap;position:absolute;bottom:16px;left:24px;right:40px}
.tag{font-size:10px;padding:2px 7px;border-radius:2px;letter-spacing:0.5px;text-transform:uppercase;font-weight:600}
.t1{background:#e8f5ee;color:#1a6b3a}
.t2{background:#e0f5f5;color:#0e6b6b}
.t3{background:#faf0e0;color:#8c5e1a}
.t4{background:#eae8fa;color:#2d1a8c}
.t5{background:#fae8f0;color:#8c1a4b}
.tg{background:#f0ede6;color:#6b6860}
.arrow{position:absolute;bottom:18px;right:20px;font-size:20px;color:#dddbd5;transition:color 0.18s,transform 0.18s}
.card:hover .arrow{transform:translateX(3px)}
.card.soon{opacity:0.5;pointer-events:none}
.card.soon::after{content:'prossimamente';position:absolute;top:14px;right:14px;font-size:9px;letter-spacing:1px;text-transform:uppercase;background:#f0ede6;color:#aaa;padding:2px 8px;border-radius:2px;font-weight:600}
footer{text-align:center;font-size:11px;color:#aaa;padding:26px;border-top:1px solid #dddbd5;letter-spacing:1px;text-transform:uppercase;margin-top:40px}
