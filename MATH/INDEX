.label::after{content:'';flex:1;height:1px;background:#dddbd5}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px}
.card{background:#fff;border:1px solid #dddbd5;border-radius:6px;padding:24px 24px 58px;text-decoration:none;color:inherit;display:block;transition:transform 0.18s,box-shadow 0.18s;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;transition:width 0.18s}
.card:hover{transform:translateY(-3px);box-shadow:0 8px 26px rgba(0,0,0,0.09)}
.card:hover::before{width:5px}
.c1::before{background:#1a6b3a}.c1:hover .arrow{color:#1a6b3a}
.c2::before{background:#0e6b6b}.c2:hover .arrow{color:#0e6b6b}
.c3::before{background:#8c5e1a}.c3:hover .arrow{color:#8c5e1a}
.c4::before{background:#2d1a8c}.c4:hover .arrow{color:#2d1a8c}
.c5::before{background:#8c1a4b}.c5:hover .arrow{color:#8c1a4b}
.num{font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#bbb;margin-bottom:8px}
.card h2{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;margin-bottom:7px;color:#1a1a1e;line-height:1.25}
